# ══════════════════════════════════════════════════════════════════════════════
# AI Operating System for Companies — Full IBM Cloud Configuration
# NO DOCKER REQUIRED — everything runs as managed cloud services
# ══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env:
#   cp .env.ibmcloud.example .env
#
# Then fill in every value marked  ← FILL THIS IN
#
# Full setup guide: IBM-CLOUD-SETUP.md
# ══════════════════════════════════════════════════════════════════════════════

# ─── What runs where ──────────────────────────────────────────────────────────
#
#   Service               Provider                   Cost
#   ──────────────────    ─────────────────────────  ──────────────────
#   LLM (Granite 3.3)     IBM watsonx.ai             Free Lite plan
#   Embeddings (768-dim)  IBM watsonx.ai             Free Lite plan
#   Knowledge Graph       Neo4j AuraDB               Free Forever tier
#   Vector Search         Qdrant Cloud               Free tier (1GB)
#   Message Bus (Redis)   IBM Cloud Databases Redis  Lite plan (free)
#   App Services          Local Python (run-local)   Your laptop
#
# ─────────────────────────────────────────────────────────────────────────────


# ═══════════════════════════
# 1. LLM PROVIDER
# ═══════════════════════════
# Keep this as "watsonx" — this is what enables IBM Cloud AI
LLM_PROVIDER=watsonx


# ═══════════════════════════
# 2. IBM watsonx.ai
# ═══════════════════════════
# How to get:  IBM-CLOUD-SETUP.md § 1-4
# Quick path:  cloud.ibm.com → Profile icon → API keys → Create

IBM_API_KEY=                                  # ← FILL THIS IN

# Your IBM Cloud region endpoint — pick the one closest to you:
#   Dallas (US)   : https://us-south.ml.cloud.ibm.com
#   Frankfurt (EU): https://eu-de.ml.cloud.ibm.com
#   Tokyo         : https://jp-tok.ml.cloud.ibm.com
#   London        : https://eu-gb.ml.cloud.ibm.com
#   Sydney        : https://au-syd.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# watsonx.ai Project ID (UUID)
# How to get:  dataplatform.cloud.ibm.com → your project → Manage → General
WATSONX_PROJECT_ID=                           # ← FILL THIS IN  (looks like: a1b2c3d4-e5f6-7890-abcd-ef1234567890)

# AI models (leave these as-is unless you have a reason to change)
WATSONX_DEFAULT_MODEL=ibm/granite-3-3-8b-instruct
WATSONX_EMBED_MODEL=ibm/slate-125m-english-rtrvr-v2


# ═══════════════════════════
# 3. NEO4J AURADB
# ═══════════════════════════
# Free cloud graph database — no install, no Docker
#
# How to create (5 min):
#   1. Go to  https://cloud.neo4j.com
#   2. Sign in (free account — no credit card needed)
#   3. Click  "New instance" → choose "AuraDB Free"
#   4. Region: pick closest to you
#   5. Click  "Create" — wait ~2 min for provisioning
#   6. COPY the credentials shown — they are displayed ONCE:
#        Username  → paste as NEO4J_USER
#        Password  → paste as NEO4J_PASSWORD
#   7. Click "Connect" button → copy the Connection URI
#        Looks like: neo4j+s://abcd1234.databases.neo4j.io
#        → paste as NEO4J_URI

NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io    # ← FILL THIS IN
NEO4J_USER=neo4j
NEO4J_PASSWORD=                                     # ← FILL THIS IN


# ═══════════════════════════
# 4. QDRANT CLOUD
# ═══════════════════════════
# Free cloud vector database — no install, no Docker
#
# How to create (5 min):
#   1. Go to  https://cloud.qdrant.io
#   2. Sign in with Google/GitHub/email (free — no credit card)
#   3. Click  "Create cluster" → choose "Free" tier
#   4. Give it a name (e.g. aios) → pick a region → click "Create"
#   5. Wait ~1 min for the cluster to start
#   6. Click your cluster → "Dashboard" tab
#   7. Find "Connection details":
#        Host: xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io  → QDRANT_HOST
#        Port: 6333                                      → QDRANT_PORT (already set)
#   8. Click "API Keys" tab → "Create API Key" → copy it → QDRANT_API_KEY

QDRANT_HOST=xxxxxxxx.us-east4-0.gcp.cloud.qdrant.io # ← FILL THIS IN
QDRANT_PORT=6333
QDRANT_API_KEY=                                      # ← FILL THIS IN
QDRANT_USE_TLS=true


# ═══════════════════════════
# 5. IBM CLOUD DATABASES FOR REDIS
# ═══════════════════════════
# Managed Redis on IBM Cloud — no Docker, TLS included
#
# How to create (5 min):
#   1. Go to  https://cloud.ibm.com/catalog/services/databases-for-redis
#   2. Choose "Lite" plan (free) → pick a region → click "Create"
#   3. Wait ~5 min for provisioning (you'll get an email)
#   4. Open your instance → "Credentials" tab → "New credential" → "Add"
#   5. Click the credential → expand JSON
#   6. Find the "connection" → "rediss" block:
#        "hosts": [{ "hostname": "...", "port": 12345 }]
#        "authentication": { "password": "..." }
#   7. Build the URL:  rediss://:<password>@<hostname>:<port>/0
#        Note: "rediss://" with double-s = TLS mode
#   8. Optionally download the TLS certificate from "Overview" → "TLS Certificate"
#      If downloaded, set REDIS_TLS_CERT_PATH to its path.

REDIS_URL=rediss://:yourpassword@host.databases.appdomain.cloud:12345/0  # ← FILL THIS IN
REDIS_TLS_CERT_PATH=                                                       # optional — path to downloaded TLS cert


# ═══════════════════════════
# 6. SOURCE CONNECTORS
# ═══════════════════════════
# Connect at least ONE source — GitHub is easiest

# GitHub Personal Access Token
# How to get: github.com → Settings → Developer Settings → Personal Access Tokens
#   → Generate new token (classic) → check "repo" + "read:org" → copy
GITHUB_APP_PRIVATE_KEY=                        # ← FILL THIS IN (ghp_...)
GITHUB_TARGET_REPOS=your-org/your-repo         # ← FILL THIS IN
GITHUB_APP_ID=
GITHUB_WEBHOOK_SECRET=

# Linear (optional)
# How to get: linear.app → Settings → API → Personal API keys
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=
LINEAR_TEAM_IDS=

# Slack (optional)
# How to get: api.slack.com/apps → create app → install to workspace
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_TARGET_CHANNELS=


# ═══════════════════════════
# 7. SECURITY
# ═══════════════════════════
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
API_KEY_SALT=change-me-run-python-secrets-token-hex-32
JWT_SECRET=change-me-run-python-secrets-token-hex-32


# ═══════════════════════════
# 8. OPERATIONAL TUNING
# ═══════════════════════════
LOG_LEVEL=INFO
ENVIRONMENT=development
ER_CONFIDENCE_THRESHOLD=0.85
MONITOR_POLL_INTERVAL_MINUTES=5
STALENESS_THRESHOLD_DAYS=30


# ═══════════════════════════
# 9. INTER-SERVICE URLS
# ═══════════════════════════
# These point to localhost because all app services run as local Python processes
# via run-local.ps1 — no Docker containers for app services
MEMORY_SERVICE_URL=http://localhost:8002
AGENTS_SERVICE_URL=http://localhost:8003
INTERFACE_SERVICE_URL=http://localhost:8001
CONNECTORS_SERVICE_URL=http://localhost:8010


# ═══════════════════════════
# UNUSED — kept for compatibility
# ═══════════════════════════
OLLAMA_BASE_URL=
OLLAMA_DEFAULT_MODEL=
OLLAMA_EMBED_MODEL=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
