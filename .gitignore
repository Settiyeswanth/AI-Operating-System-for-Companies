# ════════════════════════════════════════════════════════
# AI Operating System for Companies — .gitignore
# ════════════════════════════════════════════════════════

# ── Bob AI assistant internal workspace (NEVER commit) ───
.bob/

# ── Secrets / credentials ────────────────────────────────
.env
*.pem
*.key
*.p12
*.pfx
*.crt

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
build/
dist/
*.egg-info/
*.egg
.eggs/

# ── Virtual environments / uv ────────────────────────────
.venv/
venv/
ENV/
env/
uv.lock

# ── Testing ──────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── IDEs ─────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── Local runtime artefacts ──────────────────────────────
.aios-local-logs/
.aios-local-pids/
*.log
*.pid

# ── Database files ───────────────────────────────────────
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Temp / build ─────────────────────────────────────────
tmp/
temp/
*.tmp
*.bak
node_modules/

# ── Misc project-level exclusions ────────────────────────
push-to-github.ps1
ai-os-for-companies-engineering-execution-blueprint.html
